# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.pyc

# Distribution / packaging
.eggs/
dist/
build/
*.egg-info/

# Virtual environments
venv/
.venv/
env/

# Jupyter
.ipynb_checkpoints/

# Data & model artifacts (generated at runtime)
data/*.csv
models/*.pkl
models/*.joblib

# Saved ML model binaries (regenerate via `make train`)
model/saved_models/*.pkl
model/saved_models/*.pt

# Downloaded real-data files (regenerate via `make download-data`)
model/data/*.npy

# Django database
backend/db.sqlite3

# Plot outputs (generated at runtime) — keep .gitkeep
outputs/*
!outputs/.gitkeep

# IDE
.vscode/settings.json
.idea/

# OS
.DS_Store
Thumbs.db

# Node
node_modules/
frontend/dist/
frontend/.vite/
